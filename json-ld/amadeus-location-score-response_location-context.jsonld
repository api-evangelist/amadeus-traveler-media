{
  "@context": {
    "@version": 1.1,
    "amadeus": "https://amadeus.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "response_locationScore": "amadeus:response_locationScore",
    "meta": {
      "@id": "amadeus:meta",
      "@type": "xsd:string"
    },
    "data": {
      "@id": "amadeus:data",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "warnings": {
      "@id": "amadeus:warnings",
      "@container": "@set",
      "@type": "xsd:string"
    }
  }
}