{
  "@context": {
    "@version": 1.1,
    "amadeus": "https://amadeus.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "CollectionMeta": "amadeus:CollectionMeta",
    "CollectionLinks": "amadeus:CollectionLinks",
    "count": {
      "@id": "amadeus:count",
      "@type": "xsd:integer"
    },
    "links": {
      "@id": "amadeus:links",
      "@type": "xsd:string"
    },
    "self": {
      "@id": "amadeus:self",
      "@type": "@id"
    },
    "next": {
      "@id": "amadeus:next",
      "@type": "@id"
    },
    "previous": {
      "@id": "amadeus:previous",
      "@type": "@id"
    },
    "last": {
      "@id": "amadeus:last",
      "@type": "@id"
    },
    "first": {
      "@id": "amadeus:first",
      "@type": "@id"
    },
    "up": {
      "@id": "amadeus:up",
      "@type": "@id"
    }
  }
}